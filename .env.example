# --- Model providers ---
# NVIDIA NIM (default)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (optional, used when PROVIDER=claude or ?provider=claude)
ANTHROPIC_API_KEY=

# Default provider: llama | claude
PROVIDER=llama

# --- Database ---
# Local dev: docker compose runs postgres at postgres:5432
DATABASE_URL=postgres://joblens:joblens@localhost:5432/joblens
POSTGRES_PASSWORD=joblens

# --- Cache / Rate limit ---
REDIS_URL=redis://localhost:6379

# --- App ---
PUBLIC_BASE_URL=http://localhost:3000
RATE_LIMIT_PER_HOUR=10
LOG_LEVEL=debug
